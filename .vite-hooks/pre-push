#!/bin/sh

vp check && semgrep scan --config auto --error --quiet && vp run -r test && vp run -r build

# Scan dependencies for vulnerabilities when lockfile or manifests change
remote_ref=$(git rev-parse --abbrev-ref "@{push}" 2>/dev/null || echo "HEAD@{1}")
if git diff --name-only "$remote_ref" HEAD 2>/dev/null | grep -qE '(pnpm-lock\.yaml|package\.json|pnpm-workspace\.yaml)'; then
  vet scan --no-banner
fi
