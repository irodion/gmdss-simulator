# Service worker and manifest must never be cached by the CDN edge or browser —
# vite-plugin-pwa updates them via content-hashed asset URLs, but sw.js itself
# stays at /sw.js and needs to be re-fetched to discover updates.
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
/registerSW.js
  Cache-Control: public, max-age=0, must-revalidate
/manifest.webmanifest
  Cache-Control: public, max-age=0, must-revalidate

# Hashed asset bundles are immutable.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
