{
  "id": "v1/safety",
  "version": "1.0.0",
  "category": "safety",
  "requiredFields": [
    {
      "id": "securite",
      "label": "SECURITE signal word",
      "patterns": ["SECURITE"],
      "required": true
    },
    {
      "id": "this_is",
      "label": "THIS IS",
      "patterns": ["THIS\\s+IS"],
      "required": true
    },
    {
      "id": "vessel_name",
      "label": "Own vessel name",
      "patterns": ["BLUE\\s*DUCK"],
      "required": true
    },
    {
      "id": "nature",
      "label": "Nature of safety message",
      "patterns": ["NAVIGATIONAL\\s*WARNING|HAZARD|OBSTRUCTION|DEBRIS|UNLIT|BUOY|WRECK"],
      "required": true
    },
    {
      "id": "position",
      "label": "Position / area",
      "patterns": [
        "\\d+.*(?:NORTH|SOUTH|EAST|WEST|[NS]).*\\d+|POSITION|LATITUDE|LONGITUDE|BEARING|MILES?"
      ],
      "required": true
    }
  ],
  "prowordRules": [
    { "id": "securite", "label": "SECURITE (×3)", "pattern": "SECURITE", "expectedCount": 3 },
    { "id": "this_is", "label": "THIS IS", "pattern": "THIS\\s+IS" },
    { "id": "out", "label": "OUT", "pattern": "\\bOUT\\b" }
  ],
  "sequenceRules": {
    "fieldOrder": ["securite", "this_is", "vessel_name", "nature", "position", "out"]
  },
  "channelRules": {
    "requiredChannel": 16,
    "blockChannel70Voice": true
  }
}
