{
  "id": "v1/exam",
  "version": "1.1.0",
  "category": "distress",
  "requiredFields": [
    {
      "id": "mayday",
      "label": "MAYDAY signal word",
      "patterns": ["MAYDAY"],
      "required": true
    },
    {
      "id": "this_is",
      "label": "THIS IS",
      "patterns": ["THIS\\s+IS"],
      "required": true
    },
    {
      "id": "vessel_name",
      "label": "Own vessel name",
      "patterns": ["BLUE\\s*DUCK"],
      "required": true
    },
    {
      "id": "callsign",
      "label": "Callsign or MMSI",
      "patterns": [
        "5\\s*B\\s*C\\s*D\\s*2|FIVE\\s*BRAVO\\s*CHARLIE\\s*DELTA\\s*(TWO|2)|211\\s*239\\s*680"
      ],
      "required": true
    },
    {
      "id": "position",
      "label": "Position",
      "patterns": [
        "\\d+.{0,80}?(?:NORTH|SOUTH|EAST|WEST|\\b[NSEW]\\b)",
        "\\b(?:ZERO|ONE|TWO|THREE|FOUR|FIVE|SIX|SEVEN|EIGHT|NINE)\\b.{0,80}?(?:NORTH|SOUTH|EAST|WEST|\\b[NSEW]\\b)"
      ],
      "required": true
    },
    {
      "id": "nature",
      "label": "Nature of distress",
      "patterns": ["FIRE|FLOODING|SINKING|COLLISION|GROUNDING|CAPSIZING|ABANDON"],
      "required": true
    },
    {
      "id": "assistance",
      "label": "Assistance required",
      "patterns": ["REQUIRE.*ASSISTANCE|IMMEDIATE.*ASSISTANCE|REQUIRE.*HELP"],
      "required": true
    },
    {
      "id": "persons",
      "label": "Persons on board",
      "patterns": ["\\d+\\s*(PERSON|PERSONS|POB|SOULS)"],
      "required": true
    },
    {
      "id": "vessel_desc",
      "label": "Description of vessel",
      "patterns": [
        "(MOTOR|SAIL|YACHT|FISHING)\\s*(VESSEL|BOAT)?|METRE|METER|FEET|FOOT|BLUE|WHITE|RED"
      ],
      "required": true
    }
  ],
  "prowordRules": [
    {
      "id": "mayday",
      "label": "MAYDAY (call ×3 + message header ×1)",
      "pattern": "MAYDAY",
      "expectedCount": 4
    },
    { "id": "this_is", "label": "THIS IS", "pattern": "THIS\\s+IS" },
    { "id": "over", "label": "OVER", "pattern": "\\bOVER\\b" }
  ],
  "sequenceRules": {
    "fieldOrder": [
      "mayday",
      "this_is",
      "vessel_name",
      "callsign",
      "position",
      "nature",
      "assistance",
      "persons",
      "vessel_desc",
      "over"
    ]
  },
  "channelRules": {
    "requiredChannel": 16,
    "blockChannel70Voice": true
  },
  "dscRules": {
    "required": true,
    "beforeFirstVoiceTurn": true
  }
}
