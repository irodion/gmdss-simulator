{
  "id": "v1/distress-mob",
  "version": "1.0.0",
  "category": "distress",
  "requiredFields": [
    {
      "id": "mayday",
      "label": "MAYDAY signal word",
      "patterns": ["MAYDAY"],
      "required": true
    },
    {
      "id": "this_is",
      "label": "THIS IS",
      "patterns": ["THIS\\s+IS"],
      "required": true
    },
    {
      "id": "vessel_name",
      "label": "Own vessel name",
      "patterns": ["TABOR"],
      "required": true
    },
    {
      "id": "callsign",
      "label": "Callsign or MMSI",
      "patterns": [
        "428\\s*000\\s*666|FOUR\\s*TWO\\s*EIGHT\\s*(ZERO|ZAYRO){3}\\s*SIX\\s*SIX\\s*SIX"
      ],
      "required": true
    },
    {
      "id": "position",
      "label": "Position",
      "patterns": [
        "\\d+.{0,80}?(?:NORTH|SOUTH|EAST|WEST|\\b[NSEW]\\b)",
        "\\b(?:ZERO|ONE|TWO|THREE|FOUR|FIVE|SIX|SEVEN|EIGHT|NINE)\\b.{0,80}?(?:NORTH|SOUTH|EAST|WEST|\\b[NSEW]\\b)"
      ],
      "required": true
    },
    {
      "id": "assistance",
      "label": "Assistance required",
      "patterns": ["REQUIRE|ASSISTANCE|IMMEDIATE|HELP|SEARCH"],
      "required": true
    },
    {
      "id": "nature",
      "label": "Man overboard details",
      "patterns": ["OVERBOARD|MAN\\s*OVERBOARD|MOB|LAST\\s*SEEN|MALE|FEMALE"],
      "required": true
    },
    {
      "id": "persons",
      "label": "Persons on board",
      "patterns": ["PERSON|PERSONS|POB|CREW|SOULS|ON\\s*BOARD"],
      "required": true
    }
  ],
  "prowordRules": [
    {
      "id": "mayday",
      "label": "MAYDAY (call ×3 + message header ×1)",
      "pattern": "MAYDAY",
      "expectedCount": 4
    },
    { "id": "this_is", "label": "THIS IS", "pattern": "THIS\\s+IS" },
    { "id": "over", "label": "OVER", "pattern": "\\bOVER\\b" }
  ],
  "sequenceRules": {
