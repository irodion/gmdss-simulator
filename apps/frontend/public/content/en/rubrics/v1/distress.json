{
  "id": "v1/distress",
  "version": "1.0.0",
  "category": "distress",
  "requiredFields": [
    {
      "id": "mayday",
      "label": "MAYDAY signal word",
      "patterns": ["MAYDAY"],
      "required": true
    },
    {
      "id": "this_is",
      "label": "THIS IS",
      "patterns": ["THIS\\s+IS"],
      "required": true
    },
    {
      "id": "vessel_name",
      "label": "Own vessel name",
      "patterns": ["BLUE\\s*DUCK"],
      "required": true
    },
    {
      "id": "callsign",
      "label": "Callsign or MMSI",
      "patterns": [
        "5\\s*B\\s*C\\s*D\\s*2|FIVE\\s*BRAVO\\s*CHARLIE\\s*DELTA\\s*(TWO|2)|211\\s*239\\s*680"
      ],
      "required": true
    },
    {
      "id": "position",
      "label": "Position",
      "patterns": ["\\d+.*(?:NORTH|SOUTH|EAST|WEST|[NS]).*\\d+|POSITION|LATITUDE|LONGITUDE"],
      "required": true
    },
    {
      "id": "nature",
      "label": "Nature of distress",
      "patterns": ["FIRE|FLOODING|SINKING|COLLISION|GROUNDING|CAPSIZING|ABANDON"],
      "required": true
    },
    {
      "id": "assistance",
      "label": "Assistance required",
      "patterns": ["REQUIRE|ASSISTANCE|IMMEDIATE|HELP|EVACUAT"],
      "required": true
    },
    {
      "id": "persons",
      "label": "Persons on board",
      "patterns": ["PERSON|PERSONS|POB|CREW|SOULS|ON\\s*BOARD"],
      "required": true
    }
  ],
  "prowordRules": [
    { "id": "mayday", "label": "MAYDAY (×3)", "pattern": "MAYDAY", "expectedCount": 3 },
    { "id": "this_is", "label": "THIS IS", "pattern": "THIS\\s+IS" },
    { "id": "over", "label": "OVER", "pattern": "\\bOVER\\b" }
  ],
  "sequenceRules": {
    "fieldOrder": [
      "mayday",
      "this_is",
      "vessel_name",
      "callsign",
      "position",
      "nature",
      "assistance",
      "persons",
      "over"
    ]
  },
  "channelRules": {
    "requiredChannel": 16,
    "blockChannel70Voice": true
  }
}
