{
  "id": "v1/urgency-medico",
  "version": "1.0.0",
  "category": "urgency",
  "requiredFields": [
    {
      "id": "pan_pan",
      "label": "PAN PAN signal word",
      "patterns": ["PAN\\s*PAN"],
      "required": true
    },
    {
      "id": "this_is",
      "label": "THIS IS",
      "patterns": ["THIS\\s+IS"],
      "required": true
    },
    {
      "id": "vessel_name",
      "label": "Own vessel name",
      "patterns": [".+"],
      "required": true
    },
    {
      "id": "callsign",
      "label": "MMSI",
      "patterns": ["\\b\\d{3}[\\s-]*\\d{3}[\\s-]*\\d{3}\\b|MMSI"],
      "required": true
    },
    {
      "id": "position",
      "label": "Position",
      "patterns": [
        "\\d+.*(?:NORTH|SOUTH|EAST|WEST|[NS]).*\\d+|(?:POSITION|LATITUDE|LONGITUDE)\\b(?=.*\\d)"
      ],
      "required": true
    },
    {
      "id": "medico",
      "label": "MEDICO keyword or 'Need medical advice'",
      "patterns": ["MEDICO|MEDICAL\\s+ADVICE|MEDICAL\\s+ASSISTANCE"],
      "required": true
    }
  ],
  "prowordRules": [
    {
      "id": "pan_pan",
      "label": "PAN PAN (×3 per phase)",
      "pattern": "PAN\\s*PAN",
      "expectedCount": 3
    },
    { "id": "this_is", "label": "THIS IS", "pattern": "THIS\\s+IS" },
    { "id": "over", "label": "OVER", "pattern": "\\bOVER\\b" }
  ],
  "sequenceRules": {
    "fieldOrder": ["pan_pan", "this_is", "vessel_name", "callsign", "position", "medico", "over"]
  },
  "sequenceParts": [
    {
      "id": "procedure",
