# Production environment configuration
# Copy to .env and fill in your values
NODE_ENV=production

# Database
DATABASE_URL=postgres://gmdss:CHANGE_ME@postgres:5432/gmdss
POSTGRES_PASSWORD=CHANGE_ME

# Redis
REDIS_URL=redis://redis:6379

# Authentication — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=CHANGE_ME

# URLs
APP_URL=https://your-domain.example.com
API_URL=http://api:3001
VITE_API_URL=https://your-domain.example.com

# Caddy
SITE_ADDRESS=your-domain.example.com

# AI Provider
# Provider: "mock" (no AI, scripted responses) or "openai" (OpenAI-compatible API)
AI_PROVIDER=mock

# Uncomment for OpenAI/OpenRouter:
# AI_PROVIDER=openai
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_API_KEY=sk-or-...
# AI_STT_MODEL=whisper-1
# AI_LLM_MODEL=anthropic/claude-sonnet-4-20250514
# AI_TTS_MODEL=tts-1
